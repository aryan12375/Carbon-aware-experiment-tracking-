# EcoTrack — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────
APP_NAME="EcoTrack"
APP_VERSION="1.0.0"
ENVIRONMENT="development"           # development | staging | production
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────
# SQLite (default — zero config, perfect for dev/Colab)
DATABASE_URL="sqlite+aiosqlite:///./ecotrack.db"

# PostgreSQL (uncomment for production)
# DATABASE_URL="postgresql+asyncpg://ecotrack:password@localhost:5432/ecotrack"

# ── Grid Carbon APIs ──────────────────────────────────────────────────────
# Free tier at https://www.co2signal.com/ — 30 requests/hour
CO2SIGNAL_API_KEY=""

# Paid tier at https://app.electricitymaps.com/
ELECTRICITY_MAPS_KEY=""

# Grid region — uses CO2Signal zone codes
# India South (Karnataka): IN-SO
# India North:             IN-NO
# Germany:                 DE
# France:                  FR
# California US:           US-CAL-CISO
DEFAULT_GRID_REGION="IN-SO"

# ── Green Gate thresholds ────────────────────────────────────────────────
GATE_FAIL_ACC_DELTA_PP=0.5          # Fail if accuracy gain < 0.5 percentage points
GATE_FAIL_CO2_DELTA_PCT=20.0        # AND CO2 increase > 20%
GATE_WARN_CO2_DELTA_PCT=40.0        # Warn if CO2 increase > 40% regardless of accuracy
GATE_ABS_CO2_WARN_G=2000.0          # Warn if single run > 2kg CO2
GATE_ABS_CO2_FAIL_G=10000.0         # Fail if single run > 10kg CO2

# ── BRSR / CSRD Compliance ────────────────────────────────────────────────
ORGANISATION_NAME="MIT Manipal — EcoTrack Lab"
ORGANISATION_CIN="U72900KA2024PTC000000"
REPORTING_YEAR=2026

# ── CORS (comma-separated origins) ───────────────────────────────────────
# ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
